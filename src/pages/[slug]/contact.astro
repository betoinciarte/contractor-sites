---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import ContactForm from '../../components/ContactForm';
import { contractor, services, stats } from '../../data/demo';

const preselectedService = Astro.url.searchParams.get('service') || '';

const title = `Contact Us — ${contractor.business_name}`;
const description = `Get a free concrete estimate in ${contractor.service_areas[0]}. Call ${contractor.phone} or fill out our form. Response in 30 minutes.`;
---

<BaseLayout title={title} description={description}>
  <Nav
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    activePage="contact"
  />

  <!-- Page Header -->
  <section class="pt-32 pb-12 bg-[#F7F5F0]">
    <div class="max-w-[1200px] mx-auto px-6 text-center">
      <p class="text-[13px] uppercase tracking-[0.05em] text-[#E87C3E] font-semibold mb-3">Contact Us</p>
      <h1 class="font-heading font-extrabold text-4xl md:text-[48px] leading-[1.1] text-[#1B2B3D] mb-4">Get Your Free Estimate</h1>
      <p class="text-[#6B7C8D] text-lg max-w-xl mx-auto">
        No obligation, no pressure. We respond within 30 minutes.
      </p>
    </div>
  </section>

  <!-- Contact: Form + Info -->
  <section id="contact-form" class="py-16">
    <div class="max-w-[1100px] mx-auto px-6 grid md:grid-cols-[1fr_380px] gap-12 items-start">
      <!-- Form -->
      <div class="bg-white rounded-2xl p-8 shadow-[0_1px_3px_rgba(0,0,0,0.05)] border border-[#E5E0D8]/50">
        <h2 class="font-heading font-bold text-2xl mb-6">Request Your Free Estimate</h2>
        <ContactForm
          client:load
          services={services.map(s => ({ name: s.name }))}
          slug={contractor.slug}
          preselectedService={preselectedService}
          phone={contractor.phone}
        />
      </div>

      <!-- Info Sidebar -->
      <div class="space-y-6">
        <!-- Phone -->
        <div class="bg-white rounded-2xl p-6 shadow-[0_1px_3px_rgba(0,0,0,0.05)] border border-[#E5E0D8]/50">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-10 h-10 rounded-full bg-[#1E3D5F]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1E3D5F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <p class="text-[13px] uppercase tracking-[0.05em] text-[#6B7C8D] font-semibold">Call Us</p>
              <a href={`tel:${contractor.phoneRaw}`} class="font-heading font-bold text-xl text-[#1E3D5F] hover:text-[#E87C3E] transition-colors">
                {contractor.phone}
              </a>
            </div>
          </div>
          <p class="text-[15px] text-[#6B7C8D]">Prefer to talk? Call anytime during business hours.</p>
        </div>

        <!-- Email -->
        <div class="bg-white rounded-2xl p-6 shadow-[0_1px_3px_rgba(0,0,0,0.05)] border border-[#E5E0D8]/50">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-10 h-10 rounded-full bg-[#1E3D5F]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1E3D5F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <p class="text-[13px] uppercase tracking-[0.05em] text-[#6B7C8D] font-semibold">Email</p>
              <a href={`mailto:${contractor.email}`} class="font-heading font-bold text-lg text-[#1E3D5F] hover:text-[#E87C3E] transition-colors">
                {contractor.email}
              </a>
            </div>
          </div>
        </div>

        <!-- Hours -->
        <div class="bg-white rounded-2xl p-6 shadow-[0_1px_3px_rgba(0,0,0,0.05)] border border-[#E5E0D8]/50">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-10 h-10 rounded-full bg-[#1E3D5F]/10 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1E3D5F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-[13px] uppercase tracking-[0.05em] text-[#6B7C8D] font-semibold">Business Hours</p>
              <p class="font-heading font-bold text-lg text-[#1B2B3D]">{contractor.business_hours}</p>
            </div>
          </div>
        </div>

        <!-- Service Areas -->
        <div class="bg-white rounded-2xl p-6 shadow-[0_1px_3px_rgba(0,0,0,0.05)] border border-[#E5E0D8]/50">
          <p class="text-[13px] uppercase tracking-[0.05em] text-[#6B7C8D] font-semibold mb-3">Service Areas</p>
          <div class="flex flex-wrap gap-2">
            {contractor.service_areas.map((area) => (
              <span class="text-[13px] text-[#3D4F5F] bg-[#F7F5F0] px-3 py-1.5 rounded-full font-medium">{area}</span>
            ))}
          </div>
        </div>

        <!-- Trust signals -->
        <div class="bg-[#F7F5F0] rounded-2xl p-6 text-center">
          <div class="flex items-center justify-center gap-1 mb-2">
            <span class="text-[#F59E0B] text-xl">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="font-heading font-bold text-lg text-[#1B2B3D] mb-1">{stats.rating} Rating</p>
          <p class="text-[13px] text-[#6B7C8D]">Licensed &amp; Insured &middot; {contractor.warranty_text}</p>
        </div>
      </div>
    </div>
  </section>

  <Footer
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    licenseNumber={contractor.license_number}
    serviceAreas={contractor.service_areas}
    businessHours={contractor.business_hours}
  />

  <MobileCTA phoneRaw={contractor.phoneRaw} contactHref="#contact-form" />
</BaseLayout>
