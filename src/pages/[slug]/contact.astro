---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import ContactForm from '../../components/ContactForm';
import InlineChat from '../../components/InlineChat';
import { contractor, services, stats } from '../../data/demo';

const preselectedService = Astro.url.searchParams.get('service') || '';

const title = `Get Your Free Estimate — ${contractor.business_name}`;
const description = `Get a free concrete estimate in ${contractor.service_areas[0]}. Call ${contractor.phone} or fill out our form. Response in 30 minutes.`;
---

<BaseLayout title={title} description={description} dark>
  <Nav
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    voicePhoneRaw={contractor.voicePhoneRaw}
    activePage="contact"
  />

  <!-- Page Header -->
  <section class="pt-32 pb-12 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0e17] to-[#0f1623]"></div>
    <div class="relative z-10 max-w-[1200px] mx-auto px-6 text-center">
      <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3">Contact Us</p>
      <h1 class="font-heading font-extrabold text-4xl md:text-[48px] leading-[1.1] text-white mb-4">Get Your Free Estimate</h1>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Three ways to reach us. All take less than 60 seconds. No obligation, no pressure.
      </p>
    </div>
  </section>

  <!-- AI Quoter (Option A) -->
  <section id="quoter" class="py-16 relative">
    <div class="absolute inset-0 bg-[#0f1623]"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <div class="scroll-reveal">
        <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3">Option A: Instant AI Estimate</p>
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-white mb-3">Get your estimate in 60 seconds.</h2>
        <p class="text-white/40 text-[15px] mb-8">Our AI knows concrete pricing in {contractor.service_areas[0]}. Ask anything.</p>
      </div>
      <InlineChat client:visible slug={contractor.slug} businessName={contractor.business_name} />
    </div>
  </section>

  <!-- Form + Sidebar (Option B & C) -->
  <section id="contact-form" class="py-16 relative">
    <div class="absolute inset-0 bg-[#0a0e17]"></div>
    <div class="relative z-10 max-w-[1100px] mx-auto px-6 grid md:grid-cols-[1fr_340px] gap-8 md:gap-12 items-start pb-20 md:pb-0">
      <!-- Form (Option B) -->
      <div class="glass-card p-8">
        <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-2">Option B: Leave Your Info</p>
        <h2 class="font-heading font-bold text-2xl text-white mb-6">We call you within 30 minutes.</h2>
        <ContactForm
          client:load
          services={services.map(s => ({ name: s.name }))}
          slug={contractor.slug}
          preselectedService={preselectedService}
          phone={contractor.phone}
        />
      </div>

      <!-- Info Sidebar (Option C + Trust) -->
      <div class="space-y-6">
        <!-- Call (Option C) -->
        <div class="glass-card p-6">
          <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3">Option C: Call Us</p>
          <a href={`tel:${contractor.voicePhoneRaw}`} class="font-heading font-bold text-2xl text-white hover:text-[#E87C3E] transition-colors block mb-2">
            {contractor.phone}
          </a>
          <p class="text-white/40 text-[15px]">AI answers instantly. No voicemail. 24/7.</p>
        </div>

        <!-- Hours -->
        <div class="glass-card p-6">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-[#E87C3E]/20 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E87C3E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-[13px] uppercase tracking-[0.05em] text-white/30 font-semibold">Business Hours</p>
              <p class="font-heading font-bold text-lg text-white">{contractor.business_hours}</p>
            </div>
          </div>
        </div>

        <!-- Service Areas -->
        <div class="glass-card p-6">
          <p class="text-[13px] uppercase tracking-[0.05em] text-white/30 font-semibold mb-3">Service Areas</p>
          <div class="flex flex-wrap gap-2">
            {contractor.service_areas.map((area) => (
              <span class="text-[13px] text-white/60 bg-white/5 px-3 py-1.5 rounded-full">{area}</span>
            ))}
          </div>
        </div>

        <!-- Trust signals -->
        <div class="glass-card p-6 text-center">
          <div class="flex items-center justify-center gap-1 mb-2">
            <span class="text-[#F59E0B] text-xl">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="font-heading font-bold text-lg text-white mb-1">{stats.rating} Rating</p>
          <p class="text-[13px] text-white/40">Licensed &amp; Insured &middot; {contractor.warranty_text}</p>
        </div>

        <!-- Fear defuser -->
        <div class="glass-card p-6">
          <p class="text-white/60 text-[15px] leading-relaxed">
            Your info stays private. Fixed pricing — no surprises. We respond within 30 min. If we can't help, we'll tell you honestly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    voicePhoneRaw={contractor.voicePhoneRaw}
    licenseNumber={contractor.license_number}
    serviceAreas={contractor.service_areas}
    businessHours={contractor.business_hours}
  />

  <MobileCTA phoneRaw={contractor.voicePhoneRaw} contactHref="#quoter" />

  <script>
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.scroll-reveal').forEach(el => obs.observe(el));
  </script>
</BaseLayout>
