---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import { contractor, services } from '../../data/demo';

const title = `Our Services — ${contractor.business_name}`;
const description = `Professional concrete services: driveways, patios, foundations, stamped concrete. Serving ${contractor.service_areas.slice(0,3).join(', ')}.`;
---

<BaseLayout title={title} description={description}>
  <Nav
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    voicePhoneRaw={contractor.voicePhoneRaw}
    activePage="services"
  />

  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-[#F7F5F0]">
    <div class="max-w-[1200px] mx-auto px-6 text-center">
      <p class="text-[13px] uppercase tracking-[0.05em] text-[#E87C3E] font-semibold mb-3">What We Do</p>
      <h1 class="font-heading font-extrabold text-4xl md:text-[48px] leading-[1.1] text-[#1B2B3D] mb-4">Our Services</h1>
      <p class="text-[#6B7C8D] text-lg max-w-xl mx-auto">
        Professional concrete work backed by {contractor.years_in_business}+ years of experience. Licensed, insured, and guaranteed.
      </p>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="py-20">
    <div class="max-w-[900px] mx-auto px-6 space-y-16">
      {services.map((service, i) => (
        <div class="reveal" id={service.name.toLowerCase().replace(/\s+/g, '-')}>
          <div class="aspect-[21/9] rounded-2xl mb-8 overflow-hidden">
            <img src={service.image} alt={service.name} loading="lazy" class="w-full h-full object-cover" />
          </div>

          <div class="grid md:grid-cols-[1fr_auto] gap-8 items-start">
            <div>
              <h2 class="font-heading font-bold text-2xl md:text-3xl mb-3">{service.name}</h2>
              <p class="text-[17px] text-[#3D4F5F] leading-relaxed mb-6">{service.longDesc}</p>

              <!-- FAQ Accordion -->
              <div class="space-y-3">
                <p class="text-[13px] uppercase tracking-[0.05em] text-[#6B7C8D] font-semibold">Common Questions</p>
                {service.faqs.map((faq) => (
                  <details class="group border border-[#E5E0D8] rounded-xl overflow-hidden">
                    <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-[15px] font-medium text-[#1B2B3D] hover:bg-[#F7F5F0] transition-colors">
                      {faq.q}
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B7C8D" stroke-width="2" class="flex-shrink-0 ml-4 transition-transform group-open:rotate-180"><path d="M6 9l6 6 6-6"/></svg>
                    </summary>
                    <div class="px-5 pb-4 text-[15px] text-[#6B7C8D] leading-relaxed">{faq.a}</div>
                  </details>
                ))}
              </div>
            </div>

            <!-- Price + CTA sidebar -->
            <div class="md:sticky md:top-28 bg-[#F7F5F0] rounded-2xl p-6 text-center min-w-[220px]">
              <p class="text-[13px] uppercase tracking-[0.05em] text-[#6B7C8D] font-semibold mb-1">Starting At</p>
              <p class="font-heading font-extrabold text-2xl text-[#1E3D5F] mb-4">{service.price}</p>
              <a href={`/${contractor.slug}/contact?service=${encodeURIComponent(service.name)}`} class="block bg-[#E87C3E] text-white px-6 py-3 rounded-xl font-bold text-[15px] hover:opacity-90 transition-opacity">
                Get Your Free Estimate
              </a>
              <p class="text-[13px] text-[#6B7C8D] mt-3">No obligation. Response in 30 min.</p>
            </div>
          </div>

          {i < services.length - 1 && <hr class="mt-16 border-[#E5E0D8]" />}
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-[#1E3D5F] py-16">
    <div class="max-w-[800px] mx-auto px-6 text-center">
      <h2 class="font-heading font-bold text-3xl md:text-[36px] text-white mb-3">Not Sure What You Need?</h2>
      <p class="text-white/70 text-lg mb-8">We offer free inspections and honest advice. No upselling, no pressure.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`/${contractor.slug}/contact`} class="bg-[#E87C3E] text-white px-8 py-4 rounded-xl font-bold text-base shadow-lg hover:opacity-90 transition-opacity">
          Get Your Free Estimate
        </a>
        <a href={`tel:${contractor.voicePhoneRaw}`} class="border border-white/30 text-white px-8 py-4 rounded-xl font-semibold hover:bg-white/10 transition-all">
          {contractor.phone}
        </a>
      </div>
    </div>
  </section>

  <Footer
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    licenseNumber={contractor.license_number}
    serviceAreas={contractor.service_areas}
    businessHours={contractor.business_hours}
  />

  <MobileCTA phoneRaw={contractor.voicePhoneRaw} contactHref={`/${contractor.slug}/contact`} />
</BaseLayout>
