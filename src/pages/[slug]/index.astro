---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import InlineChat from '../../components/InlineChat';
import { contractor, services, reviews, stats, heroImage, crewImage, processImages, beforeAfterPairs, badges } from '../../data/demo';

const title = `${contractor.business_name} — Concrete in ${contractor.service_areas[0]}`;
const description = `Professional concrete services in ${contractor.service_areas.slice(0,3).join(', ')}. Licensed, insured, free estimates.`;
---

<BaseLayout title={title} description={description} dark hideChat>
  <!-- Scroll progress bar -->
  <div class="scroll-progress" id="scroll-progress"></div>

  <Nav
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    voicePhoneRaw={contractor.voicePhoneRaw}
    activePage="home"
  />

  <!-- ============================================
       ACT 1: THE HOOK — Full immersive hero
       ============================================ -->
  <section data-hero class="relative min-h-[110vh] flex items-center justify-center overflow-hidden">
    <img src={heroImage} alt="" class="absolute inset-0 w-full h-full object-cover hero-bg" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-[#0a0e17]"></div>

    <div class="relative z-10 text-center px-6 max-w-4xl">
      <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] mb-6 font-semibold hero-text-1">
        {contractor.service_areas[0]} &middot; {stats.years}+ Years &middot; {stats.projects}+ Projects
      </p>
      <h1 class="font-heading font-extrabold text-white text-[clamp(2.5rem,7vw,4.5rem)] leading-[1.05] mb-6 hero-text-2">
        Your property deserves<br />
        <span class="gradient-text">concrete you can trust.</span>
      </h1>
      <p class="text-white/60 text-lg md:text-xl mb-10 mx-auto max-w-2xl hero-text-3">
        We never sell you work you don't need. That's why {stats.rating} out of 5 homeowners rate us on Google.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center hero-text-4">
        <a href={`tel:${contractor.voicePhoneRaw}`} class="bg-[#E87C3E] text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-lg shadow-[#E87C3E]/20 hover:shadow-xl hover:shadow-[#E87C3E]/30 hover:scale-[1.03] transition-all pulse-cta">
          Call Now — AI Answers Instantly
        </a>
        <a href="#transformation" class="border border-white/20 text-white px-10 py-5 rounded-2xl font-semibold text-lg backdrop-blur-sm hover:bg-white/10 transition-all">
          See Transformations
        </a>
      </div>
    </div>

    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 bounce-down">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" opacity="0.4"><path d="M6 9l6 6 6-6"></path></svg>
    </div>
  </section>

  <!-- ============================================
       ACT 2: THE TRANSFORMATION — Scroll-driven Before/After
       ============================================ -->
  <section id="transformation" class="ba-container">
    <div class="ba-sticky" id="ba-section">
      <div class="absolute inset-0 bg-[#0a0e17]"></div>

      <div class="relative z-10 w-full max-w-5xl mx-auto px-6">
        <div class="text-center mb-8">
          <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3 scroll-reveal">Real Results</p>
          <h2 class="font-heading font-extrabold text-3xl md:text-5xl text-white scroll-reveal">
            Watch it transform.
          </h2>
          <p class="text-white/40 text-[15px] mt-3 scroll-reveal">Scroll to reveal the after</p>
        </div>

        <div class="relative aspect-[16/9] rounded-3xl overflow-hidden shadow-2xl shadow-black/50">
          <!-- Before (base layer) -->
          <img src={beforeAfterPairs[0].before} alt="Before" class="absolute inset-0 w-full h-full object-cover" id="ba-before" />
          <!-- After (clipped layer) -->
          <img src={beforeAfterPairs[0].after} alt="After" class="absolute inset-0 w-full h-full object-cover ba-after-clip" id="ba-after" />

          <!-- Labels -->
          <div class="absolute top-6 left-6 bg-black/60 backdrop-blur-sm text-white text-[13px] font-bold uppercase tracking-widest px-4 py-2 rounded-full" id="ba-label-before">Before</div>
          <div class="absolute top-6 right-6 bg-[#E87C3E]/90 backdrop-blur-sm text-white text-[13px] font-bold uppercase tracking-widest px-4 py-2 rounded-full opacity-0 transition-opacity" id="ba-label-after">After</div>

          <!-- Divider line -->
          <div class="absolute top-0 bottom-0 w-[2px] bg-white/80 shadow-[0_0_12px_rgba(255,255,255,0.4)]" id="ba-divider" style="left: 0%;">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-white rounded-full shadow-xl flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1E3D5F" stroke-width="2.5"><path d="M18 8L22 12L18 16"/><path d="M6 8L2 12L6 16"/></svg>
            </div>
          </div>
        </div>

        <p class="text-center text-white/30 text-[15px] mt-4">
          {beforeAfterPairs[0].title} &middot; {beforeAfterPairs[0].location}
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       ACT 3: THE PROCESS — Sticky section with step transitions
       ============================================ -->
  <section class="process-scroll" id="process-section">
    <div class="process-sticky">
      <div class="absolute inset-0 bg-gradient-to-b from-[#0a0e17] to-[#0f1623]"></div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-6">
        <div class="text-center mb-6">
          <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3">Our Process</p>
          <h2 class="font-heading font-extrabold text-3xl md:text-5xl text-white">
            From call to <span class="gradient-text">done.</span>
          </h2>
        </div>

        <!-- Step indicators -->
        <div class="flex justify-center gap-3 mb-10" id="step-dots">
          <div class="step-dot w-3 h-3 rounded-full bg-[#E87C3E] transition-all"></div>
          <div class="step-dot w-3 h-3 rounded-full bg-white/20 transition-all"></div>
          <div class="step-dot w-3 h-3 rounded-full bg-white/20 transition-all"></div>
        </div>

        <!-- Steps (stacked, JS controls visibility) -->
        <div class="relative h-[50vh]" id="process-cards">
          {[
            { num: '01', title: 'You Call. AI Answers.', desc: 'Our AI assistant picks up instantly — no voicemail, no waiting. It understands concrete, asks the right questions, and schedules your free estimate.', image: processImages[0] },
            { num: '02', title: 'We Pour. You Watch.', desc: 'Our crew arrives on schedule. Proper grading, reinforced base, precision pour. We send daily photo updates so you always know the status.', image: processImages[1] },
            { num: '03', title: 'Spotless. Guaranteed.', desc: "Walk-through inspection, professional cleanup, warranty documentation. 21.4% of our reviews specifically mention how clean we leave it.", image: processImages[2] },
          ].map((step, i) => (
            <div class={`process-step-card ${i === 0 ? 'active' : ''}`} data-step={i}>
              <div class="grid md:grid-cols-2 gap-8 items-center max-w-4xl mx-auto">
                <div class="order-2 md:order-1">
                  <span class="text-[#E87C3E] font-heading font-extrabold text-6xl opacity-20">{step.num}</span>
                  <h3 class="font-heading font-bold text-2xl md:text-3xl text-white mt-2 mb-4">{step.title}</h3>
                  <p class="text-white/60 text-[17px] leading-relaxed">{step.desc}</p>
                </div>
                <div class="order-1 md:order-2">
                  <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl shadow-black/40">
                    <img src={step.image} alt={step.title} class="w-full h-full object-cover" />
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       ACT 4: THE PROOF — Stats + Reviews
       ============================================ -->
  <section class="py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#0a0e17]"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20 scroll-stagger" id="stats-section">
        {[
          { value: `${stats.years}+`, label: 'Years', suffix: '' },
          { value: `${stats.projects}+`, label: 'Projects', suffix: '' },
          { value: `${stats.rating}`, label: 'Google Rating', suffix: '★' },
          { value: '52%', label: 'Recommend to Friends', suffix: '' },
        ].map((stat) => (
          <div class="glass-card p-6 md:p-8 text-center stat-entrance">
            <div class="font-heading font-extrabold text-4xl md:text-5xl text-white mb-1">
              {stat.suffix}{stat.value}
            </div>
            <div class="text-white/40 text-[13px] uppercase tracking-wider font-medium">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Reviews -->
      <div class="text-center mb-12 scroll-reveal">
        <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3">Real Reviews</p>
        <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white">
          Don't take our word for it.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 scroll-stagger">
        {reviews.map((review) => (
          <div class="glass-card p-8 relative group hover:bg-white/10 transition-colors">
            <div class="absolute top-4 right-6 text-[#E87C3E]/30 text-5xl font-serif leading-none">&ldquo;</div>
            <p class="text-white/80 text-[17px] italic leading-relaxed mb-5">&ldquo;{review.text}&rdquo;</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[#E87C3E]/20 flex items-center justify-center text-[#E87C3E] font-bold text-[15px]">
                {review.name.charAt(0)}
              </div>
              <div>
                <p class="text-white text-[15px] font-semibold">{review.name}</p>
                <p class="text-white/40 text-[13px]">{review.location} &middot; {review.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      {contractor.google_reviews_link && (
        <div class="text-center mt-10 scroll-reveal">
          <a href={contractor.google_reviews_link} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-white/50 hover:text-white text-[15px] transition-colors">
            <span class="text-[#F59E0B]">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            {stats.rating} on Google &middot; See all reviews &rarr;
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- ============================================
       ACT 5: THE ACTION — Inline Chat + Call CTA
       ============================================ -->
  <section class="py-28 relative" id="talk-to-us">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0e17] to-[#111827]"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
      <div class="scroll-reveal">
        <p class="text-[13px] uppercase tracking-[0.15em] text-[#E87C3E] font-semibold mb-3">Talk To Us Now</p>
        <h2 class="font-heading font-extrabold text-3xl md:text-5xl text-white mb-3">
          Ask us anything.
        </h2>
        <p class="text-white/40 text-lg mb-10 mx-auto">
          Our AI assistant knows concrete. Get instant answers about your project — pricing, timeline, process.
        </p>
      </div>

      <InlineChat client:visible slug={contractor.slug} businessName={contractor.business_name} />

      <div class="mt-16 scroll-reveal">
        <p class="text-white/30 text-[15px] mb-6">Prefer to talk?</p>
        <a href={`tel:${contractor.voicePhoneRaw}`} class="inline-flex items-center gap-4 bg-[#E87C3E] text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-lg shadow-[#E87C3E]/20 hover:shadow-xl hover:scale-[1.03] transition-all pulse-cta">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Call {contractor.phone}
        </a>
        <p class="text-white/20 text-[13px] mt-3">AI answers instantly &middot; No voicemail &middot; 24/7</p>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="py-20 relative">
    <div class="absolute inset-0 bg-[#111827]"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="font-heading font-bold text-2xl md:text-3xl text-white">What We Do</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 scroll-stagger">
        {services.slice(0, 6).map((s) => (
          <a href={`/${contractor.slug}/services#${s.name.toLowerCase().replace(/\s+/g, '-')}`} class="glass-card overflow-hidden group hover:bg-white/10 transition-all">
            <div class="aspect-[16/10] overflow-hidden">
              <img src={s.image} alt={s.name} loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>
            <div class="p-5">
              <h3 class="font-heading font-bold text-white text-lg">{s.name}</h3>
              <p class="text-white/40 text-[14px] mt-1">From {s.price}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8 scroll-reveal">
        <a href={`/${contractor.slug}/services`} class="text-white/50 hover:text-white text-[15px] transition-colors">
          View all services &amp; pricing &rarr;
        </a>
      </div>
    </div>
  </section>

  <Footer
    slug={contractor.slug}
    businessName={contractor.business_name}
    phone={contractor.phone}
    phoneRaw={contractor.phoneRaw}
    licenseNumber={contractor.license_number}
    serviceAreas={contractor.service_areas}
    businessHours={contractor.business_hours}
  />

  <MobileCTA phoneRaw={contractor.voicePhoneRaw} contactHref="#talk-to-us" />

  <!-- ============================================
       SCROLL ENGINE — Controls all scroll-driven effects
       ============================================ -->
  <script>
    // Scroll progress bar
    const progressBar = document.getElementById('scroll-progress');

    // Before/After scroll-driven
    const baContainer = document.querySelector('.ba-container') as HTMLElement;
    const baAfter = document.getElementById('ba-after') as HTMLElement;
    const baDivider = document.getElementById('ba-divider') as HTMLElement;
    const baLabelAfter = document.getElementById('ba-label-after') as HTMLElement;

    // Process sticky steps
    const processSection = document.getElementById('process-section') as HTMLElement;
    const processCards = document.querySelectorAll('.process-step-card');
    const stepDots = document.querySelectorAll('.step-dot');

    // Scroll handler
    function onScroll() {
      const scrollY = window.scrollY;
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;

      // Progress bar
      if (progressBar) {
        progressBar.style.setProperty('--scroll-progress', String(scrollY / maxScroll));
      }

      // Before/After
      if (baContainer && baAfter && baDivider) {
        const rect = baContainer.getBoundingClientRect();
        const containerTop = -rect.top;
        const scrollRange = baContainer.offsetHeight - window.innerHeight;
        const progress = Math.max(0, Math.min(1, containerTop / scrollRange));

        baAfter.style.setProperty('--ba-clip', `${(1 - progress) * 100}%`);
        baDivider.style.left = `${progress * 100}%`;
        if (baLabelAfter) {
          baLabelAfter.style.opacity = progress > 0.3 ? '1' : '0';
        }
      }

      // Process steps
      if (processSection) {
        const rect = processSection.getBoundingClientRect();
        const containerTop = -rect.top;
        const scrollRange = processSection.offsetHeight - window.innerHeight;
        const progress = Math.max(0, Math.min(1, containerTop / scrollRange));

        const stepIndex = Math.min(2, Math.floor(progress * 3));
        processCards.forEach((card, i) => {
          card.classList.toggle('active', i === stepIndex);
        });
        stepDots.forEach((dot, i) => {
          (dot as HTMLElement).style.background = i === stepIndex ? '#E87C3E' : 'rgba(255,255,255,0.2)';
          (dot as HTMLElement).style.width = i === stepIndex ? '2rem' : '0.75rem';
        });
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Intersection Observer for reveal animations
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.scroll-reveal, .scroll-stagger, .stat-entrance, .reveal, .reveal-stagger').forEach(el => {
      revealObserver.observe(el);
    });
  </script>
</BaseLayout>
